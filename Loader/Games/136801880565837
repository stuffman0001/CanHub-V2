-- AIM ASSIST
local aimAssist = false
local holding = false
local smoothness = 0.15

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        holding = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        holding = false
    end
end)

local function getClosest()
    local mouse = UserInputService:GetMouseLocation()
    local closest = nil
    local dist = math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - mouse).Magnitude
                if mag < dist and mag < fovRadius then
                    dist = mag
                    closest = p.Character.Head
                end
            end
        end
    end

    return closest
end

RunService.RenderStepped:Connect(function()
    if aimAssist and holding then
        local target = getClosest()
        if target then
            local camPos = Camera.CFrame.Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(camPos, target.Position), smoothness)
        end
    end
end)

Main:CreateToggle({
    Name = "Aim Assist",
    CurrentValue = false,
    Callback = function(v)
        aimAssist = v
    end
})

Main:CreateSlider({
    Name = "Smoothness",
    Range = {0.01, 1},
    Increment = 0.01,
    CurrentValue = 0.15,
    Callback = function(v)
        smoothness = v
    end
})

-- HITBOX EXPANDER
local hitboxEnabled = false
local hitboxSize = 2
local hitboxParts = {"HumanoidRootPart", "Head", "UpperTorso", "LowerTorso", "Torso"}
local originalSizes = {}

local function saveOriginalSize(part)
    if not originalSizes[part] then
        originalSizes[part] = part.Size
    end
end

local function expandHitboxes(state)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            for _, partName in pairs(hitboxParts) do
                local part = p.Character:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    saveOriginalSize(part)
                    if state then
                        part.Size = originalSizes[part] * hitboxSize
                        part.CanCollide = false
                    else
                        part.Size = originalSizes[part]
                    end
                end
            end
        end
    end
end

Main:CreateToggle({
    Name = "Hitbox Expander",
    CurrentValue = false,
    Callback = function(v)
        hitboxEnabled = v
        expandHitboxes(v)
    end
})

Main:CreateSlider({
    Name = "Hitbox Size",
    Range = {1, 5},
    Increment = 0.5,
    CurrentValue = 2,
    Callback = function(v)
        hitboxSize = v
        if hitboxEnabled then
            expandHitboxes(true)
        end
    end
})

