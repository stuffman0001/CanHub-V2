--// ANIMATE INTRO
local function animateIntro(intro)
    local ti = TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    TweenService:Create(intro.title, ti, {TextTransparency = 0}):Play()
    TweenService:Create(intro.title, ti, {TextTransparency = 0.5}):Play()

    local glowIn = TweenService:Create(intro.glow, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
        BackgroundTransparency = 0.3,
        Size = UDim2.new(0, 400, 0, 100)
    })
    glowIn:Play()

    local gradAngle = 45
    spawn(function()
        while intro.frame and intro.frame.Parent do
            gradAngle = (gradAngle + 0.15) % 360
            intro.gradient.UIGradient.Rotation = gradAngle
            RunService.RenderStepped:Wait()
        end
    end)

    spawn(function()
        while intro.shine and intro.shine.Parent do
            for i = 0, 1, 0.02 do
                if not intro.shine or not intro.shine.Parent then break end
                intro.shine.Position = UDim2.new(i, 0, 0, 0)
                RunService.RenderStepped:Wait()
            end
            task.wait(0.5)
        end
    end)

    task.wait(0.3)
    TweenService:Create(intro.subtitle, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()

    local loadWords = {"Loading...", "Loading...", "Almost there...", "Finalizing..."}
    for i = 1, 60 do
        if not intro.frame or not intro.frame.Parent then break end

        local progress = i / 60
        intro.bar.Size = UDim2.new(progress, 0, 1, 0)

        if i % 15 == 0 then
            intro.loadText.Text = loadWords[math.min(i / 15 + 1, #loadWords)]
        end

        local dots = string.rep(".", (i % 4))
        intro.loadText.Text = intro.loadText.Text:gsub("%.+", "") .. dots

        task.wait(0.03)
    end

    if intro.bar and intro.bar.Parent then
        intro.bar.Size = UDim2.new(1, 0, 1, 0)
        intro.loadText.Text = "Complete!"
    end

    task.wait(0.3)

    if intro.frame and intro.frame.Parent then
        TweenService:Create(intro.frame, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        task.wait(0.1)
        TweenService:Create(intro.title, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(intro.titleShadow, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(intro.subtitle, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(intro.glow, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        TweenService:Create(intro.loadText, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(intro.barBg, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()

        task.wait(0.5)
        intro.screenGui:Destroy()
    end
end

